{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["rules"],
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "kind"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "kind": { "type": "string", "enum": ["durable", "state", "noise"] }
        }
      }
    }
  }
}
