{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "outcome", "summary", "decisions", "issues", "rules", "entities"],
  "properties": {
    "intent": { "type": "string" },
    "outcome": { "type": "string", "enum": ["succeeded", "partial", "abandoned", "unknown"] },
    "summary": { "type": "array", "items": { "$ref": "#/definitions/evidenced" } },
    "decisions": { "type": "array", "items": { "$ref": "#/definitions/evidenced" } },
    "issues": { "type": "array", "items": { "$ref": "#/definitions/evidenced" } },
    "rules": { "type": "array", "items": { "$ref": "#/definitions/evidenced" } },
    "entities": { "type": "array", "items": { "type": "string" } }
  },
  "definitions": {
    "evidenced": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "msgs"],
      "properties": {
        "text": { "type": "string" },
        "msgs": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 2,
          "maxItems": 2
        }
      }
    }
  }
}
